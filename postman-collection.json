{
  "info": {
    "name": "Multi-Vendor E-Commerce Platform",
    "description": "Complete API collection for the multi-vendor e-commerce platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "authUrl", "value": "http://localhost:3001" },
    { "key": "sellerUrl", "value": "http://localhost:3002" },
    { "key": "catalogUrl", "value": "http://localhost:3003" },
    { "key": "orderUrl", "value": "http://localhost:3005" },
    { "key": "shippingUrl", "value": "http://localhost:3007" },
    { "key": "buyerToken", "value": "" },
    { "key": "sellerToken", "value": "" },
    { "key": "orderId", "value": "" },
    { "key": "productId", "value": "" },
    { "key": "shipmentId", "value": "" },
    { "key": "sellerId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Seller",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.accessToken) {",
                  "  pm.collectionVariables.set('sellerToken', res.accessToken);",
                  "  console.log('Seller token saved');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{authUrl}}/api/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Seller\",\n  \"email\": \"seller_{{$timestamp}}@test.com\",\n  \"password\": \"password123\",\n  \"role\": \"seller\"\n}"
            }
          }
        },
        {
          "name": "Register Buyer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.accessToken) {",
                  "  pm.collectionVariables.set('buyerToken', res.accessToken);",
                  "  console.log('Buyer token saved');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{authUrl}}/api/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Buyer\",\n  \"email\": \"buyer_{{$timestamp}}@test.com\",\n  \"password\": \"password123\",\n  \"role\": \"buyer\"\n}"
            }
          }
        },
        {
          "name": "Login Buyer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.accessToken) {",
                  "  pm.collectionVariables.set('buyerToken', res.accessToken);",
                  "  console.log('Buyer token saved');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{authUrl}}/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"buyer@test.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login Seller",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.accessToken) {",
                  "  pm.collectionVariables.set('sellerToken', res.accessToken);",
                  "  console.log('Seller token saved');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{authUrl}}/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"seller@test.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "url": "{{authUrl}}/api/auth/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{buyerToken}}" }]
          }
        }
      ]
    },
    {
      "name": "Seller",
      "item": [
        {
          "name": "Create Store",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res._id) {",
                  "  pm.collectionVariables.set('sellerId', res.userId);",
                  "  console.log('Seller store created');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{sellerUrl}}/api/sellers/store",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{sellerToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"storeName\": \"Test Store\",\n  \"description\": \"My awesome store\"\n}"
            }
          }
        },
        {
          "name": "Get My Store",
          "request": {
            "method": "GET",
            "url": "{{sellerUrl}}/api/sellers/store",
            "header": [{ "key": "Authorization", "value": "Bearer {{sellerToken}}" }]
          }
        },
        {
          "name": "Update Store",
          "request": {
            "method": "PUT",
            "url": "{{sellerUrl}}/api/sellers/store",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{sellerToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"storeName\": \"Updated Store Name\",\n  \"description\": \"Updated description\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Create Product",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res._id) {",
                  "  pm.collectionVariables.set('productId', res._id);",
                  "  console.log('Product ID saved:', res._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{sellerUrl}}/api/products",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{sellerToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Test Phone\",\n  \"description\": \"A great product\",\n  \"category\": \"electronics/phones\",\n  \"price\": 9999,\n  \"images\": []\n}"
            }
          }
        },
        {
          "name": "Get My Products",
          "request": {
            "method": "GET",
            "url": "{{sellerUrl}}/api/products",
            "header": [{ "key": "Authorization", "value": "Bearer {{sellerToken}}" }]
          }
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PUT",
            "url": "{{sellerUrl}}/api/products/{{productId}}",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{sellerToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Product\",\n  \"price\": 8999\n}"
            }
          }
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "url": "{{sellerUrl}}/api/products/{{productId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{sellerToken}}" }]
          }
        }
      ]
    },
    {
      "name": "Catalog",
      "item": [
        {
          "name": "Search Products",
          "request": {
            "method": "GET",
           "url": "http://localhost:3003/api/catalog/search?keyword=phone"
          }
        },
        {
          "name": "Browse by Category",
          "request": {
            "method": "GET",
            "url": "http://localhost:3003/api/catalog/category/electronics"
          }
        },
        {
          "name": "Get Product by ID",
          "request": {
            "method": "GET",
            "url": "http://localhost:3003/api/catalog/{{productId}}"
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Place Order",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res._id) {",
                  "  pm.collectionVariables.set('orderId', res._id);",
                  "  console.log('Order ID saved:', res._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{orderUrl}}/api/orders",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{buyerToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    {\n      \"productId\": \"{{productId}}\",\n      \"sellerId\": \"{{sellerId}}\",\n      \"qty\": 1,\n      \"price\": 9999\n    }\n  ],\n  \"shippingAddress\": {\n    \"street\": \"123 Main St\",\n    \"city\": \"Toronto\",\n    \"zip\": \"M1A 1A1\",\n    \"country\": \"Canada\"\n  }\n}"
            }
          }
        },
        {
          "name": "Get My Orders",
          "request": {
            "method": "GET",
            "url": "{{orderUrl}}/api/orders",
            "header": [{ "key": "Authorization", "value": "Bearer {{buyerToken}}" }]
          }
        },
        {
          "name": "Get Order by ID",
          "request": {
            "method": "GET",
            "url": "{{orderUrl}}/api/orders/{{orderId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{buyerToken}}" }]
          }
        },
        {
          "name": "Cancel Order",
          "request": {
            "method": "POST",
            "url": "{{orderUrl}}/api/orders/{{orderId}}/cancel",
            "header": [{ "key": "Authorization", "value": "Bearer {{buyerToken}}" }]
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Get Payment by Order",
          "request": {
            "method": "GET",
            "url": "http://localhost:3006/api/payments/order/{{orderId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{buyerToken}}" }]
          }
        },
        {
          "name": "Refund Payment",
          "request": {
            "method": "POST",
            "url": "http://localhost:3006/api/payments/refund",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{buyerToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": \"{{orderId}}\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Shipping",
      "item": [
        {
          "name": "Create Shipment",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res._id) {",
                  "  pm.collectionVariables.set('shipmentId', res._id);",
                  "  console.log('Shipment ID saved:', res._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{shippingUrl}}/api/shipping",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{sellerToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": \"{{orderId}}\",\n  \"carrier\": \"FedEx\",\n  \"trackingNumber\": \"TRACK123456\",\n  \"estimatedDelivery\": \"2026-04-01\"\n}"
            }
          }
        },
        {
          "name": "Update Shipment Status",
          "request": {
            "method": "PUT",
            "url": "{{shippingUrl}}/api/shipping/{{shipmentId}}/status",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{sellerToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"delivered\"\n}"
            }
          }
        },
        {
          "name": "Carrier Webhook - Mark Delivered",
          "request": {
            "method": "POST",
            "url": "{{shippingUrl}}/api/shipping/webhook",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"shipmentId\": \"{{shipmentId}}\",\n  \"status\": \"delivered\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Reviews",
      "item": [
        {
          "name": "Submit Review",
          "request": {
            "method": "POST",
            "url": "http://localhost:3008/api/reviews",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{buyerToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"orderId\": \"{{orderId}}\",\n  \"rating\": 5,\n  \"body\": \"Great product!\"\n}"
            }
          }
        },
        {
          "name": "Get Reviews by Product",
          "request": {
            "method": "GET",
            "url": "http://localhost:3008/api/reviews/product/{{productId}}"
          }
        },
        {
          "name": "Get Pending Reviews",
          "request": {
            "method": "GET",
            "url": "http://localhost:3008/api/reviews/pending",
            "header": [{ "key": "Authorization", "value": "Bearer {{buyerToken}}" }]
          }
        }
      ]
    },
    {
      "name": "Search",
      "item": [
        {
          "name": "Search Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:3011/api/search/search?keyword=phone",
              "query": [{ "key": "keyword", "value": "phone" }]
            }
          }
        },
        {
          "name": "Get Categories",
          "request": {
            "method": "GET",
            "url": "http://localhost:3011/api/search/categories"
          }
        },
        {
          "name": "Get Featured Products",
          "request": {
            "method": "GET",
            "url": "http://localhost:3011/api/search/featured"
          }
        }
      ]
    },
    {
      "name": "Analytics",
      "item": [
        {
          "name": "Get Platform Stats",
          "request": {
            "method": "GET",
            "url": "http://localhost:3012/api/analytics/stats",
            "header": [{ "key": "Authorization", "value": "Bearer {{buyerToken}}" }]
          }
        },
        {
          "name": "Get Top Products",
          "request": {
            "method": "GET",
            "url": "http://localhost:3012/api/analytics/top-products",
            "header": [{ "key": "Authorization", "value": "Bearer {{buyerToken}}" }]
          }
        },
        {
          "name": "Get Daily GMV",
          "request": {
            "method": "GET",
            "url": "http://localhost:3012/api/analytics/gmv",
            "header": [{ "key": "Authorization", "value": "Bearer {{buyerToken}}" }]
          }
        }
      ]
    },
    {
      "name": "OAuth2",
      "item": [
        {
          "name": "Authorize (open in browser)",
          "request": {
            "method": "GET",
            "url": "{{authUrl}}/oauth/authorize?response_type=code&client_id=test-client&redirect_uri=http://localhost:3000/callback&scope=catalog:read orders:create"
          }
        },
        {
          "name": "Exchange Code for Tokens",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.accessToken) {",
                  "  pm.collectionVariables.set('buyerToken', res.accessToken);",
                  "  console.log('OAuth2 token saved');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{authUrl}}/oauth/token",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"grant_type\": \"authorization_code\",\n  \"code\": \"paste_code_here\",\n  \"client_id\": \"test-client\",\n  \"client_secret\": \"test-secret\",\n  \"redirect_uri\": \"http://localhost:3000/callback\"\n}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{authUrl}}/api/auth/refresh",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"paste_refresh_token_here\"\n}"
            }
          }
        }
      ]
    }
  ]
}